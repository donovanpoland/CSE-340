<%- include('partials/head', { title, keywords, desc }) %>
<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <p class="lede">Here are a few of our partner organizations:</p>
    <ul class="rmv_liststyle">
        <% organizations.forEach(organization => { %>
        <li class="card">
            <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
            <div><strong><%= organization.name %></strong>: <%= organization.contact_email %></div>
        </li>
        <% }); %>
    </ul>
</main>
<%- include('partials/footer') %>
