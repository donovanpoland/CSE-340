<!DOCTYPE html>
<html lang="en"> <!-- thml end tag in footer -->
<head>
    <title><%= title %></title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="keywords" content="<%= keywords %>">
    <meta name="author" content="Donovan Poland">
    <meta name="description" content="<%= desc %>">
    <meta name="robots" content="index, follow">
    <!-- Scripts -->
    <script src="/scripts/scripts.js" defer></script>

    <!-- CSS style sheets -->
    <link rel="stylesheet" href="/css/styles.css">

    <!-- Font links-->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500;6..72,700&display=swap" rel="stylesheet">
    <!-- Open Graph protocol meta tags -->
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="<%= desc %>">
    <meta property="og:url" content="">
    <meta property="og:image" content="link to image here">
    <meta property="og:locale" content="en_US">
    <!-- Favicon.ico -->
    <link rel="icon" href="">
</head>
